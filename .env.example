# Enterprise Agent 本地配置示例
#
# 现在配置分三层：
# 1. 启动必需：服务连接数据库、队列、解密 DB secret 前必须由环境变量提供。
# 2. 运行参数：已支持写入 PostgreSQL runtime config，但 api-server/worker 当前仍保留 env fallback。
# 3. 密钥引用：topology YAML/数据库里只保存 secret_ref，真实值由 env 或 DB secret provider 解析。

# -----------------------------------------------------------------------------
# 启动必需：不要放进同一个 PostgreSQL 配置库
# -----------------------------------------------------------------------------
DATABASE_DSN=postgresql://enterprise_agent:enterprise_agent@postgres:5432/enterprise_agent
APP_ENV=local
APP_STARTUP_MIGRATE=true
SEED_LOCAL_CONFIG=false
APP_CONFIG_MASTER_KEY=replace-with-local-dev-master-key

# Compose 基础设施镜像。默认跟随主版本补丁更新；生产环境请覆盖为已经验证的
# 完整补丁标签（例如 postgres:18.x / rabbitmq:4.x-management）或 image digest。
POSTGRES_IMAGE=postgres:18
RABBITMQ_IMAGE=rabbitmq:4-management

# -----------------------------------------------------------------------------
# Agent 功能开关：可迁入 runtime config，当前仍保留 env fallback
# -----------------------------------------------------------------------------
FEATURE_REAL_INTERNAL_TOOLS=true
FEATURE_REAL_CLAUDE=true

# -----------------------------------------------------------------------------
# Internal API Platform：Agent 只通过这个只读平台访问 MySQL/Redis/Loki
# -----------------------------------------------------------------------------
INTERNAL_API_BASE_URL=http://internal-api-platform:9000
INTERNAL_API_AUTH_TOKEN=
INTERNAL_API_TIMEOUT_SECONDS=10
INTERNAL_API_MAX_RESPONSE_CHARS=4000
INTERNAL_PLATFORM_TOPOLOGY_FILE=/app/backend/config/internal_platform_topology.example.yaml
INTERNAL_PLATFORM_MAX_ROWS=100

# -----------------------------------------------------------------------------
# topology secret://* 本地 fallback（填真实值到 .env，勿提交仓库）
# Oracle SERVICE=CRMES；业务 schema 见各基地 SCHEMA 注释（CRMES_TEST_*）
# -----------------------------------------------------------------------------
# 三九 · 观澜云端
SECRET_SANJIU_GUANLAN_CLOUD_DB_HOST=
SECRET_SANJIU_GUANLAN_CLOUD_DB_USER=
SECRET_SANJIU_GUANLAN_CLOUD_DB_PASSWORD=
# 三九 · 观澜边端
SECRET_SANJIU_GUANLAN_EDGE_DB_HOST=
SECRET_SANJIU_GUANLAN_EDGE_DB_USER=
SECRET_SANJIU_GUANLAN_EDGE_DB_PASSWORD=
SECRET_SANJIU_GUANLAN_EDGE_REDIS_PASSWORD=
# 三九 · 顺丰云端
SECRET_SANJIU_SHUNFENG_CLOUD_DB_HOST=
SECRET_SANJIU_SHUNFENG_CLOUD_DB_USER=
SECRET_SANJIU_SHUNFENG_CLOUD_DB_PASSWORD=
# 三九 · 顺丰边端
SECRET_SANJIU_SHUNFENG_EDGE_DB_HOST=
SECRET_SANJIU_SHUNFENG_EDGE_DB_USER=
SECRET_SANJIU_SHUNFENG_EDGE_DB_PASSWORD=
SECRET_SANJIU_SHUNFENG_EDGE_REDIS_PASSWORD=
# 三九 · 郴州云端
SECRET_SANJIU_CHENZHOU_CLOUD_DB_HOST=
SECRET_SANJIU_CHENZHOU_CLOUD_DB_USER=
SECRET_SANJIU_CHENZHOU_CLOUD_DB_PASSWORD=
# 三九 · 郴州边端
SECRET_SANJIU_CHENZHOU_EDGE_DB_HOST=
SECRET_SANJIU_CHENZHOU_EDGE_DB_USER=
SECRET_SANJIU_CHENZHOU_EDGE_DB_PASSWORD=
SECRET_SANJIU_CHENZHOU_EDGE_REDIS_PASSWORD=
# 三九 · 云端 Redis Cluster（观澜/顺丰/郴州云端共用）
SECRET_SANJIU_CLOUD_REDIS_PASSWORD=
# 新腾 MySQL
SECRET_XT_MES51_DB_HOST=
SECRET_XT_MES51_DB_USER=
SECRET_XT_MES51_DB_PASSWORD=
# 蒙牛 SQL Server
SECRET_MMK_MAIN_DB_HOST=
SECRET_MMK_MAIN_DB_USER=
SECRET_MMK_MAIN_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Agent 测试数据环境：仅用于本地 agent-test-data profile
# ARM64：MySQL/Redis 使用多架构镜像；SQL Server 显式 linux/amd64，
# 必须通过健康检查，失败时请改用 x86-64 Docker 主机验收。
# -----------------------------------------------------------------------------
AGENT_TEST_MYSQL_IMAGE=mysql:8.4
AGENT_TEST_SQLSERVER_IMAGE=mcr.microsoft.com/mssql/server:2022-latest
AGENT_TEST_SQLSERVER_PLATFORM=linux/amd64
AGENT_TEST_REDIS_IMAGE=redis:7.4

AGENT_TEST_MYSQL_HOST_PORT=3307
AGENT_TEST_SQLSERVER_HOST_PORT=14330
AGENT_TEST_REDIS_MYSQL_HOST_PORT=6381
AGENT_TEST_REDIS_SQLSERVER_HOST_PORT=6382

AGENT_TEST_MYSQL_DATABASE=agent_test
AGENT_TEST_MYSQL_ROOT_PASSWORD=AgentTest_mysql_root_2026
AGENT_TEST_SQLSERVER_DATABASE=agent_test
AGENT_TEST_SQLSERVER_SA_PASSWORD=AgentTest_sqlserver_sa_2026!

# agent_test/mysql 只读运行凭据（topology secret://agent_test/mysql/*）
# 端口以 topology YAML 为准（mysql 3306 / redis 6379），不在此重复配置。
SECRET_AGENT_TEST_MYSQL_DB_HOST=agent-test-mysql
SECRET_AGENT_TEST_MYSQL_DB_USER=agent_test_reader
SECRET_AGENT_TEST_MYSQL_DB_PASSWORD=agent_test_reader_mysql
SECRET_AGENT_TEST_MYSQL_REDIS_HOST=agent-test-redis-mysql
SECRET_AGENT_TEST_MYSQL_REDIS_USER=agent_test_reader
SECRET_AGENT_TEST_MYSQL_REDIS_PASSWORD=agent_test_reader_redis_mysql
AGENT_TEST_REDIS_MYSQL_ADMIN_PASSWORD=agent_test_redis_mysql_admin
AGENT_TEST_REDIS_MYSQL_SEEDER_USER=agent_test_seeder
AGENT_TEST_REDIS_MYSQL_SEEDER_PASSWORD=agent_test_seeder_redis_mysql

# agent_test/sqlserver 只读运行凭据（topology secret://agent_test/sqlserver/*）
# 端口以 topology YAML 为准（sqlserver 1433 / redis 6379），不在此重复配置。
SECRET_AGENT_TEST_SQLSERVER_DB_HOST=agent-test-sqlserver
SECRET_AGENT_TEST_SQLSERVER_DB_USER=agent_test_reader
SECRET_AGENT_TEST_SQLSERVER_DB_PASSWORD=AgentTest_reader_sqlserver_2026
SECRET_AGENT_TEST_SQLSERVER_REDIS_HOST=agent-test-redis-sqlserver
SECRET_AGENT_TEST_SQLSERVER_REDIS_USER=agent_test_reader
SECRET_AGENT_TEST_SQLSERVER_REDIS_PASSWORD=agent_test_reader_redis_sqlserver
AGENT_TEST_REDIS_SQLSERVER_ADMIN_PASSWORD=agent_test_redis_sqlserver_admin
AGENT_TEST_REDIS_SQLSERVER_SEEDER_USER=agent_test_seeder
AGENT_TEST_REDIS_SQLSERVER_SEEDER_PASSWORD=agent_test_seeder_redis_sqlserver
# agent_test 两基地共用 Loki（默认与 LOKI_BASE_URL 相同）
SECRET_AGENT_TEST_LOKI_BASE_URL=http://host.docker.internal:3100

# -----------------------------------------------------------------------------
# Loki 查询限制：真实拓扑从数据库读，限制参数仍保留 env/runtime-config fallback
# -----------------------------------------------------------------------------
LOKI_BASE_URL=http://host.docker.internal:3100
LOKI_MAX_MINUTES=60
LOKI_MAX_LINES=500
LOKI_MAX_RESPONSE_CHARS=4000
LOKI_TENANT_ID=tenant1

# -----------------------------------------------------------------------------
# 钉钉 Stream 入口：正式用户消息入口，不需要公网 HTTP callback
# -----------------------------------------------------------------------------
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_STREAM_ENABLED=true
DINGTALK_STREAM_CONNECTOR_ID=connector-dingtalk-stream-default
DINGTALK_STREAM_RECONNECT_INITIAL_SECONDS=5
DINGTALK_STREAM_RECONNECT_MAX_SECONDS=60
DINGTALK_STREAM_WORKER_ID=dingtalk-stream-ingress

# -----------------------------------------------------------------------------
# 钉钉结果投递与默认业务路由：消息没有显式路由时使用这些默认值
# -----------------------------------------------------------------------------
DINGTALK_DEFAULT_DELIVERY_TYPE=dingtalk_enterprise_robot
DINGTALK_DEFAULT_DELIVERY_CONNECTOR_ID=connector-dingtalk-enterprise-default
DINGTALK_DEFAULT_SOURCE_CONNECTOR_ID=connector-dingtalk-stream-default
DINGTALK_DEFAULT_PROJECT_CODE=default
DINGTALK_DEFAULT_ENVIRONMENT=
DINGTALK_DEFAULT_BASE=
DINGTALK_DEFAULT_WORKSHOP=
DINGTALK_DEFAULT_SERVICE=
DINGTALK_DEFAULT_OPEN_CONVERSATION_ID=
DINGTALK_DEFAULT_ROBOT_CODE=

# -----------------------------------------------------------------------------
# 兼容 Anthropic 协议的模型运行时
# FEATURE_REAL_CLAUDE=true 会调用外部模型 API；内部数据外发前需要确认策略。
# -----------------------------------------------------------------------------
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=your-deepseek-api-key
ANTHROPIC_AUTH_TOKEN=your-deepseek-api-key
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
CLAUDE_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max

# -----------------------------------------------------------------------------
# Agent 执行与 RabbitMQ consumer 调优
# -----------------------------------------------------------------------------
AGENT_MAX_TURNS=12
RABBITMQ_CONSUMER_HEARTBEAT_SECONDS=900
RABBITMQ_CONSUMER_RECONNECT_SECONDS=5
