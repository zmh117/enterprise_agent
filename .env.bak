# Runtime feature switches.
FEATURE_REAL_CLAUDE=true
FEATURE_REAL_INTERNAL_TOOLS=true

# DingTalk enterprise app credentials. Used by Stream ingress and enterprise app delivery.
DINGTALK_CLIENT_ID=dingb9feetjdec11m5wb
DINGTALK_CLIENT_SECRET=lGlbg_VK2aPHzkkuMYLZqsAJoMbfATzjV2Gpk9tL2zZK5vJuBIW4CXUmmczOrTMc

# DingTalk Stream ingress. This is the formal DingTalk user-message entrypoint.
DINGTALK_STREAM_ENABLED=true
DINGTALK_STREAM_CONNECTOR_ID=connector-dingtalk-stream-default
DINGTALK_STREAM_RECONNECT_INITIAL_SECONDS=5
DINGTALK_STREAM_RECONNECT_MAX_SECONDS=60
DINGTALK_STREAM_WORKER_ID=dingtalk-stream-ingress

# DingTalk result delivery defaults. Stream ingress creates jobs; delivery sends final results.
DINGTALK_DEFAULT_DELIVERY_TYPE=dingtalk_enterprise_robot
DINGTALK_DEFAULT_DELIVERY_CONNECTOR_ID=connector-dingtalk-enterprise-default
DINGTALK_DEFAULT_SOURCE_CONNECTOR_ID=connector-dingtalk-stream-default
DINGTALK_DEFAULT_OPEN_CONVERSATION_ID=你的钉钉群 openConversationId
DINGTALK_DEFAULT_ROBOT_CODE=你的企业机器人 robotCode

# Default diagnostic routing scope used when DingTalk messages do not include routing.
DINGTALK_DEFAULT_PROJECT_CODE=default
DINGTALK_DEFAULT_ENVIRONMENT=sanjiu
DINGTALK_DEFAULT_BASE=guanlan
DINGTALK_DEFAULT_WORKSHOP=GL001
DINGTALK_DEFAULT_SERVICE=order-service

# Optional DingTalk webhook robot delivery. Delivery only; never used as user-message ingress.
DINGTALK_WEBHOOK_ROBOT_URL=https://oapi.dingtalk.com/robot/send?access_token=7ffc3b1e7dda00d292d1b543386f0b4c7191f04a1e9ba0a677bf18f961d32a00
DINGTALK_WEBHOOK_ROBOT_SECRET=SECc0b832d5965f10ed62acddaca2407a51899e7192e68ec6c8b635fd850edf2de5

# For mock HTTP tool-flow verification, run:
# docker compose --profile mock-tools up -d --build
# and set INTERNAL_API_BASE_URL=http://mock-internal-api-platform:9000
#
# For real Claude + local Loki verification, run:
# docker compose --profile local-tools up -d --build
# and set INTERNAL_API_BASE_URL=http://local-internal-api-platform:9000
#
# For the topology-aware multi-dialect platform (三九/mmk), run:
# docker compose --profile real-tools up -d --build
# and set INTERNAL_API_BASE_URL=http://internal-api-platform:9000
# Internal API Platform endpoint used by read-only Agent tools.
INTERNAL_API_BASE_URL=http://internal-api-platform:9000
INTERNAL_API_AUTH_TOKEN=test-test
INTERNAL_API_TIMEOUT_SECONDS=10
INTERNAL_API_MAX_RESPONSE_CHARS=4000

# Internal API Platform (topology-aware). Point this at a real topology file.
INTERNAL_PLATFORM_TOPOLOGY_FILE=/app/backend/config/internal_platform_topology.example.yaml
INTERNAL_PLATFORM_MAX_ROWS=100
# Secrets referenced by the topology as secret://<path>; resolved from SECRET_<UPPER_SNAKE>.
#但 internal-api-platform 跑在 Docker 容器里，容器里的 localhost 指容器自己，不是你 Mac 上的 MySQL
SECRET_SANJIU_GUANLAN_DB_HOST=host.docker.internal
SECRET_SANJIU_GUANLAN_DB_USER=root
SECRET_SANJIU_GUANLAN_DB_PASSWORD=root
SECRET_SANJIU_GUANLAN_REDIS_HOST=localhost
SECRET_SANJIU_GUANLAN_LOKI_URL=http://host.docker.internal:3100

# Loki defaults used by local/internal tool adapters.
LOKI_BASE_URL=http://host.docker.internal:3100
LOKI_MAX_MINUTES=60
LOKI_MAX_LINES=500
LOKI_MAX_RESPONSE_CHARS=4000
LOKI_TENANT_ID=tenant1

# Anthropic-compatible runtime endpoint and credentials.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-6db34ab0044b4ab4872704ae72f704d4
ANTHROPIC_API_KEY=sk-6db34ab0044b4ab4872704ae72f704d4

ANTHROPIC_MODEL=deepseek-v4-pro[1m]
CLAUDE_MODEL=deepseek-v4-pro[1m]

ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max

# Agent runtime limits and RabbitMQ consumer tuning.
AGENT_MAX_TURNS=12
RABBITMQ_CONSUMER_HEARTBEAT_SECONDS=900
RABBITMQ_CONSUMER_RECONNECT_SECONDS=5
